# Google Analytics Measurement ID (e.g., G-XXXXXXXXXX)
# If configured, the app will enable Google Analytics tracking
# Injected into client/index.html at build time (see client/vite.config.ts).
# Either name works; VITE_ matches Vite’s usual client-env convention.
GOOGLE_ANALYTICS_KEY='G-XXXXXXXXXX'
# VITE_GOOGLE_ANALYTICS_KEY='G-XXXXXXXXXX'
